---
export interface Props {
    mode?: 'download' | 'view'; // default: download
}

const { mode = 'download' } = Astro.props;

// Determine link href and text based on mode
const linkHref = mode === 'download' ? '/assets/pdfs/resume.pdf' : '/resume';
const linkText = mode === 'download' ? 'DOWNLOAD' : 'RESUME';

// Set extra attributes for download mode
const extraAttrs = mode === 'download' ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<div class="resume-box-wrapper u:mt-fluid-xl u:w-full">
    <div class="resume-box u:flex u:w-full u:items-center u:justify-center u:text-center">
        <a
            class="glitchable resume-box-text hover-text u:tracking-wide"
            href={linkHref}
            {...extraAttrs}
        >
            {linkText}
        </a>
    </div>
</div>
