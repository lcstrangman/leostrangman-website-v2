---
import '@styles/global.css';
import { SEO } from 'astro-seo';
import { defaultSeo, type Seo } from '@data/seo';
import { getSeo } from '@scripts/utils/seo';
import { themes, type ThemeKey } from '@data/themes';
import Icon from '@components/Icon/Icon.astro';

interface Props {
    title?: string;
    seo?: Seo;
    pageTitle?: string;
    theme?: ThemeKey;
}

const {
    title = 'INDEX',
    seo = {},
    pageTitle = 'INDEX',
    theme = 'index',
} = Astro.props;

const t = themes[theme];

const currentUrl = `${Astro.site}${Astro.url.pathname}`;
const seoData = getSeo(seo, defaultSeo, title, currentUrl);
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" href="/favicon.svg" />
        <link rel="shortcut icon" href="/favicon.ico" />
        <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
        <link rel="manifest" href="/site.webmanifest" />
        <meta name="generator" content={Astro.generator} />
        <SEO {...seoData} />
    </head>

    <body
        style={`
            --primary-color: ${t.primaryColor};
            --primary-contrast-color: ${t.primaryContrastColor};
            --secondary-color: ${t.secondaryColor};
            --secondary-contrast-color: ${t.secondaryContrastColor};
            --tertiary-color: ${t.tertiaryColor};
            --tertiary-contrast-color: ${t.tertiaryContrastColor};
            --quaternary-color: ${t.quaternaryColor};
            --quaternary-contrast-color: ${t.quaternaryContrastColor};
            --page-title: ${pageTitle};
        `}
    >
        <!-- Mouse follower -->
        <div class="mouse-circle" aria-hidden="true"></div>

        <!-- Loading screens -->
        <div role="banner" aria-label="Loading Screen">
            <!-- Shown briefly on every page load -->
            <div id="initial-screen">
                <div class="icon-wrapper u:select-none">
                    <Icon class="hover-text" name="icon-amber-supply" />
                </div>
            </div>

            <!-- Full loading screen, first visit only -->
            <div id="loading-screen">
                <div class="loading-content">
                    <div class="loading-top">
                        <Icon class="loading-icon" name="icon-amber-supply" />
                        <span class="loading-name-text" id="loading-name-text"></span>
                    </div>
                    <p class="loading-note">
                        For the full animated experience, use a desktop browser
                    </p>
                </div>
            </div>

            <!-- Single canvas used for all wipe transitions — replaces the 2500-div grid -->
            <canvas
                id="loading-canvas"
                aria-hidden="true"
                style="position:fixed;inset:0;z-index:10002;pointer-events:none;"
            ></canvas>
        </div>

        <!-- Main content -->
        <div class="site-container" role="main">
            <main
                id="swup"
                class="transition-fade"
                data-primary-color={t.primaryColor}
                data-primary-contrast-color={t.primaryContrastColor}
                data-secondary-color={t.secondaryColor}
                data-secondary-contrast-color={t.secondaryContrastColor}
                data-tertiary-color={t.tertiaryColor}
                data-tertiary-contrast-color={t.tertiaryContrastColor}
                data-quaternary-color={t.quaternaryColor}
                data-quaternary-contrast-color={t.quaternaryContrastColor}
                data-page-title={pageTitle}
            >
                <div id="content">
                    <slot />
                </div>
            </main>

            <!-- Footer -->
            <footer
                class="u:w-full font-nikkei background-color footer-selection u:flex u:justify-between u:py-fluid-s u:px-4"
                style="color: var(--primary-contrast-color);"
            >
                <div>&copy;{new Date().getFullYear()}</div>
                <nav class="font-nikkei footer-selection u:flex u:gap-gutter">
                    <a class="glitchable hover-text" href="/">Home</a>
                    <a class="glitchable hover-text" href="/projects">Projects</a>
                    <a class="glitchable hover-text" href="/work">My Work</a>
                    <a class="glitchable hover-text" href="/about">About Me</a>
                    <a class="glitchable hover-text" href="/contact">Contact</a>
                </nav>
            </footer>
        </div>

        <script src="../scripts/app.ts"></script>
        <style>
            .font-nikkei {
                font-family: 'Nikkei';
            }
            .footer-selection {
                user-select: none;
            }
        </style>
    </body>
</html>